# Xuexibao backend environment
# Copy this file to backend/.env and fill in your local or production values.
# Do not commit backend/.env.

# development or production
APP_ENV=development

# Development default: SQLite file under backend/xuexibao.db
# Production recommendation: PostgreSQL, for example:
# DATABASE_URL=postgresql://xuexibao_user:<password>@postgres:5432/xuexibao
DATABASE_URL=sqlite:///./xuexibao.db

# Required in production. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Required in production. In development, leaving this empty falls back to dev-invite.
INVITE_CODE=

ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated frontend origins.
# Development: leave empty to allow all origins.
# Production: set your real frontend origin, for example:
# CORS_ORIGINS=https://xuexibao.example.com
CORS_ORIGINS=

# OpenAI-compatible AI provider configuration.
# Examples:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat
# OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
# OPENAI_MODEL=mimo-v2.5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Chat limits and upstream timeout.
CHAT_RATE_LIMIT_PER_HOUR=20
CHAT_MAX_MESSAGE_LENGTH=4000
CHAT_MAX_HISTORY_MESSAGES=20
CHAT_MAX_HISTORY_TOTAL_LENGTH=20000
CHAT_UPSTREAM_TIMEOUT=90

# AI import usually takes longer than chat because files are split into chunks.
IMPORT_UPSTREAM_TIMEOUT=90
IMPORT_CHUNK_SIZE=5000
IMPORT_MAX_CHUNKS=3
IMPORT_RATE_LIMIT_PER_HOUR=10

# Optional Redis URL for accurate rate limiting across workers.
REDIS_URL=

# Default 0: backend/.env wins over stale Windows user/system env variables.
# Set to 1 only when a deployment platform must override .env values.
PRESERVE_SYSTEM_ENV=0
