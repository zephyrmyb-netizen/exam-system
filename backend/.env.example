# Exam System 后端环境变量
# 复制此文件为 .env 并根据需要修改

# 运行环境：development（开发，默认）或 production（生产）
# 开发环境允许使用默认 SECRET_KEY / INVITE_CODE（启动时会有 warning）
# 生产环境必须设置所有独立的安全配置，否则拒绝启动
APP_ENV=development

# 数据库连接（默认 SQLite，也可换成 PostgreSQL 等）
# 默认值为绝对路径，数据库文件生成在 backend/exam_system.db
DATABASE_URL=sqlite:///./exam_system.db

# JWT 密钥 — 必须修改！
# 开发环境：留空则使用默认值，启动会显示 warning
# 生产环境：必须设为随机长字符串，且设置 APP_ENV=production
# 生成方式（Windows / Linux / macOS 通用）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# 注册邀请码 — 生产环境必须修改！
# 开发环境：留空则使用默认值 'dev-invite'（启动会显示 warning）
# 生产环境：必须设置唯一邀请码，否则拒绝启动
INVITE_CODE=

# Token 过期时间（分钟，默认 1440 = 24 小时）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允许的来源（逗号分隔，不要有空格）
# 开发环境：留空自动允许所有来源（*），方便本地调试
# 生产环境：必须设置为前端真实域名，localhost / 127.0.0.1 / * 会被拒绝
# 例如：CORS_ORIGINS=https://exam.example.com
CORS_ORIGINS=

# ── AI 接口配置（兼容 OpenAI API 格式） ──────────────────────────────────
#
# 以下三个变量同时影响 /chat 对话和 /imports/file/auto 自动导入。
#
# 示例 1：OpenAI
#   OPENAI_API_KEY=<your-api-key>
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
#
# 示例 2：DeepSeek
#   OPENAI_API_KEY=<your-api-key>
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
#
# 示例 3：自定义兼容接口（如 Mimo）
#   OPENAI_API_KEY=<your-api-key>
#   OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
#   OPENAI_MODEL=mimo-v2.5
#
# 不配置时默认使用 OpenAI，默认模型 gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── AI 对话安全限制 ────────────────────────────────────────────────────
# 每小时每用户最大请求次数（默认 20）
CHAT_RATE_LIMIT_PER_HOUR=20
# 单条消息最大字符数（默认 4000）
CHAT_MAX_MESSAGE_LENGTH=4000
# 历史消息最大条数（默认 20）
CHAT_MAX_HISTORY_MESSAGES=20
# 历史消息总字符数上限（默认 20000）
CHAT_MAX_HISTORY_TOTAL_LENGTH=20000
# 上游 AI 接口超时秒数（默认 30）
CHAT_UPSTREAM_TIMEOUT=30
