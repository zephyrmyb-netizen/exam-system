# Exam System 后端环境变量
# 复制此文件为 .env 并根据需要修改

# 运行环境：development（开发，默认）或 production（生产）
# 开发环境允许使用默认 SECRET_KEY（启动时会有 warning）
# 生产环境必须设置独立的 SECRET_KEY，否则拒绝启动
APP_ENV=development

# 数据库连接（默认 SQLite，也可换成 PostgreSQL 等）
# 默认值为绝对路径，数据库文件生成在 backend/exam_system.db
DATABASE_URL=sqlite:///./exam_system.db

# JWT 密钥 — 必须修改！
# 开发环境：留空则使用默认值，启动会显示 warning
# 生产环境：必须设为随机长字符串，且设置 APP_ENV=production
# 生成方式（Windows PowerShell / 终端）：
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# 注册邀请码（默认 dev-invite，生产环境请修改）
INVITE_CODE=dev-invite

# Token 过期时间（分钟，默认 1440 = 24 小时）
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允许的来源（逗号分隔，不要有空格）
# 开发阶段可用 *（留空自动 fallback），生产环境设置为前端实际地址
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ── AI 接口配置（兼容 OpenAI API 格式） ──────────────────────────────────
#
# 以下三个变量同时影响 /chat 对话和 /imports/file/auto 自动导入。
#
# 示例 1：OpenAI
#   OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
#
# 示例 2：DeepSeek
#   OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
#   OPENAI_BASE_URL=https://api.deepseek.com/v1
#   OPENAI_MODEL=deepseek-chat
#
# 示例 3：自定义兼容接口（如 Mimo）
#   OPENAI_API_KEY=your-key-here
#   OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
#   OPENAI_MODEL=mimo-v2.5
#
# 不配置时默认使用 OpenAI，默认模型 gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
