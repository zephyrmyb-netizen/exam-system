{
  "name": "xuexibao-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "pinia": "^3.0.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.13",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.6.0",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^15.11.0",
    "prettier": "^3.9.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.2.0"
  }
}
