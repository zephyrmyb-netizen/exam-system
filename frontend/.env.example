# Xuexibao frontend environment
# Copy this file to frontend/.env when you need to override the API address.

# Local desktop:
VITE_API_BASE_URL=http://127.0.0.1:8000

# Mobile LAN testing example:
# VITE_API_BASE_URL=http://192.168.1.8:8000

# Production behind the provided Nginx container can use same-origin API calls.
# In that case, omit this variable or set it to your real API origin.
