# Auto-detect text files and normalize to LF
* text=auto

# Declare LF for all source files
*.py text eol=lf
*.js text eol=lf
*.vue text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Keep Windows-native files as-is
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
*.zip binary
*.db binary
*.sqlite binary
*.sqlite3 binary
